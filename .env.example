# --- Supabase (recommended for Vercel + production): run supabase/migrations/001_create_leads.sql in SQL Editor
# Server-only: use service_role JWT (eyJ...) or secret key (sb_secret_...) from Project Settings → API.
# Do not use the publishable (sb_publishable_) key on the server if RLS blocks writes — it behaves like anon.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # or sb_secret_...
# Optional alias: SUPABASE_SECRET_KEY=...

GROQ_API_KEY=your_groq_key
# Optional override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
PORT=3001

# --- Gmail-only (send + receive in your Gmail inbox) ---
EMAIL_PROVIDER=gmail
GMAIL_USER=you@gmail.com
# REQUIRED: 16-char App Password from Google (Security → 2-Step Verification ON → App passwords).
# Never use your normal Gmail password — Google returns 535 BadCredentials. Spaces optional (stripped automatically).
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_DISPLAY_NAME=Amay Varghese

# --- Optional: Resend instead (opens/clicks/replies via webhooks) ---
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your_resend_key
# RESEND_FROM_EMAIL=Amay Varghese <hello@yourdomain.com>
# RESEND_INBOUND_EMAIL=replies@yourdomain.resend.app
# REPLY_TO_EMAIL=you@gmail.com
# RESEND_WEBHOOK_SECRET=your_webhook_signing_secret

# Resume attachment (use one) — attached to every send:
# Local: file in repo root (path relative to backend/)
# RESUME_FILE_PATH=../amay-varghese-resume(1).docx
# Or under backend/: RESUME_FILE_PATH=public/resume.pdf
# Vercel: use a public HTTPS URL (e.g. raw GitHub after push):
# RESUME_PUBLIC_URL=https://raw.githubusercontent.com/USER/REPO/main/amay-varghese-resume%281%29.docx
# RESUME_FILENAME=Amay_Varghese_Resume.docx
